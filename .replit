modules = ["nodejs-22", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bun run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "bun install && bun run build"]
run = ["sh", "-c", "PORT=5000 HOST=0.0.0.0 bun run start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
